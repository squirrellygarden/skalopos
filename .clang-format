---
# Skalapos C style. See CLAUDE.md "Coding conventions" for rules clang-format cannot enforce.
BasedOnStyle: LLVM

# Indentation
IndentWidth:        4
TabWidth:           4
UseTab:             Never
ContinuationIndentWidth: 4

# Line length — soft target ~90, hard cap ~110
ColumnLimit:        100

# Pointer style: `void * foo`, not `void* foo` or `void *foo`
PointerAlignment:   Middle
DerivePointerAlignment: false

# Braces — opening brace on same line (Attach), including functions
BreakBeforeBraces:  Attach

# Align consecutive #define and #include groups; NOT variable declarations
AlignConsecutiveMacros:
  Enabled:          true
  AcrossEmptyLines: false
  AcrossComments:   false
AlignConsecutiveDeclarations:
  Enabled:          false

# Single-space before trailing // comments
SpacesBeforeTrailingComments: 1

# Keep // comment spacing: exactly one space after //
SpacesInLineCommentPrefix:
  Minimum:  1
  Maximum:  1

# No space inside parens, brackets; standard spacing elsewhere
SpacesInParens:     Never
SpacesInSquareBrackets: false
SpaceBeforeParens:  ControlStatements
SpaceAfterCStyleCast: false

# Don't sort #includes — include order is intentional in kernel code
SortIncludes:       Never

# Allow short functions, ifs, and loops to stay on one line only if they're truly trivial
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortBlocksOnASingleLine: Empty
